#Utilizando o "%" que serve para representar vários caracteres (ou nenhum) em buscas com LIKE #
select ProductID,
		ProductName,
        UnitPrice,
        UnitsInStock,
        (UnitPrice * UnitsInStock) as 'total por produto',
        CategoryID
from products
where (CategoryID = 1 or CategoryID = 3) and ProductName like 'C%i';



# Utilizando dois "% %" para poder buscar os valores com um espaço no meio #
select ProductID,
		ProductName,
        UnitPrice,
        UnitsInStock,
        (UnitPrice * UnitsInStock) as 'total por produto',
        CategoryID
from products
where (CategoryID = 1 or CategoryID = 3) and ProductName like '% %';



# Utilizando o _ (anderline) que serve para representar um único caractere qualquer em buscas com LIKE #
select ProductID,
		ProductName,
        UnitPrice,
        UnitsInStock,
        (UnitPrice * UnitsInStock) as 'Total por Produto',
        CategoryID
from products
where (CategoryID = 1 or CategoryID = 3) and ProductName like 'G_a%a';



# Utilizando o "in" que é usado para verificar se um valor está dentro de uma lista de valores, ele funciona como um jeito mais curto de escrever vários OR #
select ProductID,
		ProductName,
        UnitPrice,
        UnitsInStock,
        (UnitPrice * UnitsInStock) as 'Total por Produto',
        CategoryID
from products
where CategoryID in (1,3) and ProductName like 'G_a%a';



# Selecionando a tabela "products", colocando oque deve aparecer e utilizando o "order by" para poder ordenar e o "asc" para poder deixar em ordem crescente # 
select ProductID,
		ProductName,
        UnitPrice,
        UnitsInStock,
        (UnitPrice * UnitsInStock) as 'Total por Produto',
        CategoryID
from products
order by UnitPrice asc;



# Selecionando a tabela "orders", colocando oque deve aparecer e utilizando o "order by" para poder ordenar e o "asc" para poder deixar em ordem crescente #
select OrderID,
		CustomerID,
        EmployeeID,
        OrderDate
from orders
order by orderdate asc;



# utilizando os Operadores Lógicos para pode filtrar o "OrderDate" #
select OrderID,
		CustomerID,
        EmployeeID,
        OrderDate
from orders
where OrderDate >= '19960101' and  OrderDate <= '19961231'
order by OrderDate asc;



# Utilizando o "between" para poder filtrar o "OrderDate" sem utilizar os Operadores Lógicos #
select OrderID,
		CustomerID,
        EmployeeID,
        OrderDate
from orders
where OrderDate between '19960101' and '19961231'
order by OrderDate asc;



# Utilizando o "year" para poder filtrar o "OrderDate" #
select OrderID,
		CustomerID,
        EmployeeID,
        OrderDate
from orders
where year (OrderDate) = '1996'
order by OrderDate asc;



